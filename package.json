{
  "name": "rapidashboard",
  "version": "1.0.0",
  "description": "A free react dashboard components set",
  "main": "./lib/cjs/index.js",
  "module": "./lib/esm/index.js",
  "types": "./lib/esm/index.d.ts",
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs",
    "build:esm": "tsc",
    "build:cjs": "tsc --module commonjs --outDir lib/cjs",
    "dev": "tsc --watch"
  },
  "keywords": [
    "react",
    "dashboard"
  ],
  "author": "Douglas Zanotta <douglas.z.porto@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^17.0.41",
    "@types/react-dom": "^17.0.14",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "typescript": "^4.6.2"
  },
  "peerDependencies": {
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  }
}
